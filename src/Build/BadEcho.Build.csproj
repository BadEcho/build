<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Title>Bad Echo MSBuild Extensions</Title>
		<AssemblyTitle>$(Title)</AssemblyTitle>
		<Product>$(Title)</Product>
		<Description>Adds custom MSBuild tasks used by Bad Echo projects.</Description>
		<IsPackable>true</IsPackable>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<MajorVersion>0</MajorVersion>
		<MinorVersion>1</MinorVersion>
		<PatchVersion>6</PatchVersion>
		<VersionPrefix>$(MajorVersion).$(MinorVersion).$(PatchVersion)</VersionPrefix>
		<AssemblyVersion>$(MajorVersion).0.0.0</AssemblyVersion>
		<FileVersion>$(MajorVersion).$(MinorVersion).$(PatchVersion).0</FileVersion>
		<!--This is an MSBuild Task package, not a library, which means our assets (including the dependency list we'll be generating) will be in 'tasks' instead of 'lib'.-->
		<BuildOutputTargetFolder>tasks</BuildOutputTargetFolder>
	</PropertyGroup>

	<!--Places our property/target files into 'build' for automatic inclusion in the buililld process.-->
	<ItemGroup>
		<Content Include="BadEcho.Build.props" PackagePath="build\" />
		<Content Include="BadEcho.Build.targets" PackagePath="build\" />
	</ItemGroup>

	<!--
	MSBuild Task packages need to have their dependencies bundled with them, as opposed to the having those dependencies exposed to consuming projects.
	This requires marking all dependencies below as private, followed by the generation of a dependency list.
	-->
	<ItemGroup>
		<!--The only dependency we don't want bundled with the package is the Microsoft.Build.Utilities.Core assembly, as MSBuild provides this dependency at runtime.-->
		<PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.4.0" PrivateAssets="all" ExcludeAssets="Runtime" />
		<!--
		Note that this package does not, at the time of writing, have any other dependencies we need to bundle with it; however, if we ever need to add one or more dependencies
		in the future, at least they'll be properly handled.
		-->
	</ItemGroup>
	<ItemGroup>
		<Compile Update="Properties\Strings.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Strings.resx</DependentUpon>
		</Compile>
	</ItemGroup>

	<PropertyGroup>
		<!--Next, we hook into the target that collects the files to be packaged.-->
		<TargetsForTfmSpecificBuildOutput>
			$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage
		</TargetsForTfmSpecificBuildOutput>
		<!--All dependencies need to be copied into the output folder for bundling.-->
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<!--NuGet normally warns about libraries in a package not exposed as dependencies. We do not want this behavior for this package.-->
		<NoWarn>NU5100,NU5128</NoWarn>
	</PropertyGroup>

	<!--This will move all referenced assets to the package output.-->
	<Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
		<ItemGroup>
			<BuildOutputInPackage Include="@(ReferenceCopyLocalPaths)" TargetPath="%(ReferenceCopyLocalPaths.DestinationSubPath)" />
		</ItemGroup>
	</Target>

	<!--
	Finally, we create a deps.json file and add it to our package output. All of this is required because dependency lists are not generated by default for libraries, 
	and we need one to ensure the correct versions of our Task package's dependencies are loaded.
	-->
	<PropertyGroup>
		<GenerateDependencyFile>true</GenerateDependencyFile>
	</PropertyGroup>

	<Target Name="AddDependencyFileToOutputGroup" BeforeTargets="BuiltProjectOutputGroup" Condition=" '$(GenerateDependencyFile)' == 'true'">
		<ItemGroup>
			<BuiltProjectOutputGroupOutput Include="$(ProjectDepsFilePath)" TargetPath="$(ProjectDepsFileName)" FinalOutputPath="$(ProjectDepsFilePath)" />
		</ItemGroup>
	</Target>

	<ItemGroup>
		<EmbeddedResource Update="Properties\Strings.resx">
			<Generator>ResXFileCodeGenerator</Generator>
			<LastGenOutput>Strings.Designer.cs</LastGenOutput>
		</EmbeddedResource>
		<None Include="README.md" Pack="true" PackagePath="" />
	</ItemGroup>

</Project>