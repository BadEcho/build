<Project>

	<PropertyGroup>
		<TaskAssemblyPath>$(MSBuildThisFileDirectory)..\tasks\netstandard2.1\$(MSBuildThisFileName).dll</TaskAssemblyPath>
	</PropertyGroup>

	<UsingTask TaskName="BadEcho.Build.ReadJsonFile" AssemblyFile="$(TaskAssemblyPath)" Runtime="NET" Architecture="*" />
	<UsingTask TaskName="BadEcho.Build.Git" AssemblyFile="$(TaskAssemblyPath)" Runtime="NET" Architecture="*" />

	<PropertyGroup>
		<ReleaseBuild Condition="'$(ReleaseBuild)' == ''">false</ReleaseBuild>
		<DependencyReleaseBuild Condition="'$(DependencyReleaseBuild)' == ''">false</DependencyReleaseBuild>
		<RootPath Condition="'$(RootPath)' == ''">..\..</RootPath>
		<VersionJsonName Condition="'$(VersionJsonName)' == ''">version.json</VersionJsonName>
		<VersionJsonPath Condition="'$(VersionJsonPath)' == ''">$(RootPath)\$(VersionJsonName)</VersionJsonPath>
		<VersionPropertiesPath Condition="'$(VersionPropertiesPath)' == ''">$(RootPath)\Version.props</VersionPropertiesPath>
		<MajorVersion Condition="'$(MajorVersion)' == ''">0</MajorVersion>
		<MinorVersion Condition="'$(MinorVersion)' == ''">1</MinorVersion>
		<PatchVersion Condition="'$(PatchVersion)' == ''">0</PatchVersion>
		<BuildNumber Condition="'$(BuildNumber)' == ''">0</BuildNumber>
		<AssemblyVersion>$(MajorVersion).0.0.0</AssemblyVersion>
	</PropertyGroup>

</Project>